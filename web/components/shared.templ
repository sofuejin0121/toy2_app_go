package components

import "fmt"

// ErrorMessages はバリデーションエラーメッセージの一覧を表示するコンポーネント
templ ErrorMessages(errors []string) {
    if len(errors) > 0 {
        <div id="error_explanation">
            <div class="alert alert-danger">
                The from contains {fmt.Sprintf("%d",len(errors)) } error(s).
            </div>
            <ul>
                for _, e := range errors {
                    <li>{ e }</li>
                }
            </ul>
        </div>
    }
}